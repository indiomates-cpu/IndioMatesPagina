# =============================================================
#  Indio Mates — Variables de entorno
#  Copiá este archivo como `.env` y completá los valores.
# =============================================================

# -------- Base de datos (PostgreSQL) --------
# Formato: postgresql://USUARIO:CONTRASENA@HOST:PUERTO/NOMBRE_DB?schema=public
# Ejemplo local:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/indio_mates?schema=public"

# -------- WhatsApp --------
# Número/s del negocio en formato internacional SIN "+", espacios ni guiones.
# Ejemplo Argentina (cód. país 54 + 9 para celular + área sin 0 + número sin 15):
# 5493764123456
NEXT_PUBLIC_WHATSAPP_NUMBER="5493764000000"

# Segundo número (opcional): al confirmar un pedido, se elige al azar entre
# este y el de arriba (50/50) para repartir los pedidos entre los dos socios.
# Si lo dejás vacío, todos los pedidos van al número principal.
NEXT_PUBLIC_WHATSAPP_NUMBER_2=""

# -------- Autenticación del panel admin --------
# Clave para firmar los JWT. Generá una cadena larga y aleatoria, por ejemplo:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="cambia-esto-por-una-clave-larga-y-secreta"

# Credenciales del administrador inicial que crea el seed.
ADMIN_USUARIO="admin"
ADMIN_CONTRASENA="indiomates2024"

# -------- Cloudinary (imágenes) --------
# Si dejás estas variables vacías, el panel permite cargar imágenes por URL
# (útil para desarrollo con placeholders). Al completarlas se habilita la
# subida de archivos con optimización automática.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
# Nombre público del cloud (mismo valor que CLOUDINARY_CLOUD_NAME), disponible en el cliente.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
